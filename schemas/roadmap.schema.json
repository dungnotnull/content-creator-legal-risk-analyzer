{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Prioritized Improvement Roadmap",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["title", "effort", "impact", "success_metric", "phase", "dimension"],
    "properties": {
      "title": {"type": "string", "minLength": 3},
      "effort": {"type": "string", "enum": ["Small", "Medium", "Large"]},
      "impact": {"type": "string", "enum": ["High", "Medium", "Low"]},
      "success_metric": {"type": "string", "minLength": 5},
      "phase": {"type": "string", "enum": ["Quick wins", "Major projects", "Long-term"]},
      "dimension": {"type": "string", "minLength": 2}
    }
  }
}
